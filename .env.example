# Copy to .env and fill in. Used by docker-compose.yml → mediamtx.cloud.yml.

# This host's PUBLIC IP or domain — clients use it for WebRTC ICE.
MTX_PUBLIC_HOST=media.sentry.chipmo.mn

# Store agents authenticate with these to PUBLISH their camera streams.
# Returned to paired agents by backend GET /api/v1/agent/stream-config.
MTX_PUBLISH_USER=chipmo-agent
MTX_PUBLISH_PASS=change-me-publish-secret

# sentry-backend authenticates with these to add/remove paths via the API.
MTX_API_USER=chipmo-backend
MTX_API_PASS=change-me-api-secret
