# sentry-ai .env for the Predator "center" connecting to the RAILWAY backend.
# Copy to  <repo>\sentry-ai\.env  and fill the marked values.

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8001

# Ollama runs locally on this machine (RTX 4060).
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_PROVIDER=minicpm-v-2.6
INFERENCE_TIMEOUT_SEC=30

# ── Talk back to the Railway backend ────────────────────────────────────────
# Public Railway URL of sentry-backend.
SENTRY_BACKEND_URL=https://sentry-backend-XXXX.up.railway.app

# IMPORTANT: this MUST equal the backend's LIVE_METADATA_SHARED_SECRET env var,
# or live-metadata POSTs are rejected (401) and /live overlays stay empty.
SENTRY_BACKEND_SERVICE_TOKEN=replace-with-shared-secret-matching-backend
